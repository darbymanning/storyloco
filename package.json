{
	"name": "storyloco",
	"version": "1.17.0",
	"description": "A collection of slick Storyblok field plugins built with Svelte 5, TypeScript, and Tailwind CSS",
	"keywords": [
		"storyblok",
		"field-plugin",
		"svelte",
		"typescript",
		"tailwind",
		"cms",
		"headless"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/darbymanning/storyloco.git"
	},
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"files": [
		"src",
		"packages/mux/types.ts",
		"packages/heading/types.ts",
		"packages/plans/types.ts",
		"packages/link/types.ts",
		"packages/asset/types.ts",
		"packages/asset/r2.ts",
		"packages/theme/types.ts",
		"packages/shared/dist",
		"packages/vite/dist",
		"packages/ticketsource/types.ts",
		"packages/input/types.ts",
		"packages/time/types.ts",
		"packages/seo/types.ts"
	],
	"exports": {
		".": {
			"types": "./packages/vite/dist/storyblok.svelte.d.ts",
			"import": "./packages/vite/dist/storyblok.svelte.js"
		},
		"./mux": {
			"types": "./packages/mux/types.ts"
		},
		"./heading": {
			"types": "./packages/heading/types.ts"
		},
		"./plans": {
			"types": "./packages/plans/types.ts"
		},
		"./ticketsource": {
			"types": "./packages/ticketsource/types.ts",
			"svelte": "./packages/ticketsource/src/app.svelte.ts"
		},
		"./input": {
			"types": "./packages/input/types.ts",
			"svelte": "./packages/input/src/app.svelte.ts"
		},
		"./shared": {
			"types": "./packages/shared/dist/index.d.ts",
			"svelte": "./packages/shared/dist/index.js"
		},
		"./link": {
			"types": "./packages/link/types.ts"
		},
		"./asset": {
			"types": "./packages/asset/types.ts"
		},
		"./shared/utils": {
			"types": "./packages/shared/dist/utils.d.ts",
			"svelte": "./packages/shared/dist/utils.js"
		},
		"./vite": {
			"types": "./packages/vite/dist/index.d.ts",
			"import": "./packages/vite/dist/index.js"
		},
		"./hooks": {
			"types": "./packages/vite/dist/hooks.d.ts",
			"import": "./packages/vite/dist/hooks.js"
		},
		"./time": {
			"types": "./packages/time/types.ts",
			"svelte": "./packages/time/src/app.svelte.ts"
		},
		"./seo": {
			"types": "./packages/seo/types.ts"
		}
	},
	"devDependencies": {
		"@types/node": "26.1.1",
		"@typescript-eslint/eslint-plugin": "8.64.0",
		"@typescript-eslint/parser": "8.64.0",
		"eslint": "10.7.0",
		"kitto": "1.6.0",
		"oxfmt": "0.59.0",
		"typescript": "5.9.3",
		"vite": "8.1.5"
	},
	"peerDependencies": {
		"@storyblok/svelte": "7.2.2",
		"@storyblok/field-plugin": "^1.7.1",
		"svelte": "^5.0.0"
	},
	"scripts": {
		"add-plugin": "npx @storyblok/field-plugin-cli@latest add --dir \"./packages\" --structure monorepo",
		"build": "cd packages/vite && npm run build && cd ../../packages/shared && npm run build",
		"lint": "oxfmt --check && eslint --ext .js .",
		"format": "oxfmt"
	},
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"dependencies": {
		"ora": "9.4.1",
		"path-to-regexp": "8.4.2"
	}
}
