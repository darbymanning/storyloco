{
	"name": "uiloco-heading",
	"version": "0.0.0",
	"devDependencies": {
		"@storyblok/field-plugin": "1.6.0",
		"@sveltejs/vite-plugin-svelte": "5.1.0",
		"@tsconfig/svelte": "5.0.4",
		"oxfmt": "0.55.0",
		"shared": "../shared",
		"svelte": "5.34.8",
		"svelte-check": "4.2.2",
		"typescript": "5.8.3",
		"vite": "7.0.0",
		"vite-plugin-css-injected-by-js": "3.5.2"
	},
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
		"deploy": "bun run build && bunx @storyblok/field-plugin-cli@latest deploy --dotEnvPath '../../.env' --skipPrompts --scope partner-portal",
		"format": "oxfmt"
	},
	"type": "module"
}
