{
	"name": "uiloco-theme",
	"version": "0.0.0",
	"devDependencies": {
		"@storyblok/field-plugin": "1.7.0",
		"@sveltejs/vite-plugin-svelte": "6.2.1",
		"@tsconfig/svelte": "5.0.5",
		"oxfmt": "0.55.0",
		"radashi": "12.6.2",
		"shared": "../shared",
		"svelte": "5.38.5",
		"svelte-check": "4.3.1",
		"typescript": "5.9.2",
		"vite": "7.2.2",
		"vite-plugin-css-injected-by-js": "3.5.2"
	},
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
		"deploy": "bun run build && bunx @storyblok/field-plugin-cli@latest deploy --dotEnvPath '../../.env' --skipPrompts --scope partner-portal",
		"format": "oxfmt"
	},
	"type": "module"
}
